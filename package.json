{
  "name": "shotlens",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "start": "bun --filter '*' start",
    "test": "bun --filter '*' test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:generate": "bun run --cwd packages/db db:generate"
  },
  "dependencies": {
    "@kdunin/component-library": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
