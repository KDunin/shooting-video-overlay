# --- Database -------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ipsclab
DATABASE_URL=postgres://postgres:postgres@postgres:5432/ipsclab

# --- Media storage --------------------------------------------------------
# Inside containers this is the shared volume mount; locally point it anywhere writable.
MEDIA_DIR=/media

# --- API ------------------------------------------------------------------
API_PORT=3001
MAX_UPLOAD_BYTES=2147483648

# --- Web ------------------------------------------------------------------
API_URL=http://localhost:3001
VITE_BASE_URL=http://localhost:3000

# Auth is disabled for the single-user MVP. Set AUTH_ENABLED=true and fill the
# Logto values below to turn on multi-user auth (already scaffolded).
AUTH_ENABLED=false
# LOGTO_ENDPOINT=
# LOGTO_APP_ID=
# LOGTO_APP_SECRET=
# LOGTO_COOKIE_SECRET=

# --- Private package registry (component library) -------------------------
# Required for `bun install` to fetch @kdunin/component-library from GitHub Packages.
NPM_TOKEN=
